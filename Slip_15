package com.example.studentdetails;
import android.os.Bundle;
import android.view.Gravity;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
public class MainActivity2 extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main2);
        android.content.Intent intent = getIntent();
        TableLayout tl = findViewById(R.id.tableLayout);
        String[][] data = {
            {"Field","Value"},
            {"Name",    intent.getStringExtra("name")},
            {"Surname", intent.getStringExtra("surname")},
            {"Class",   intent.getStringExtra("clazz")},
            {"Gender",  intent.getStringExtra("gender")},
            {"Hobbies", intent.getStringExtra("hobbies")},
            {"Marks",   intent.getStringExtra("marks")},
        };
        boolean header = true;
        for (String[] row : data) {
            TableRow tr = new TableRow(this);
            for (String cell : row) {
                TextView tv = new TextView(this);
                tv.setText(cell);
                tv.setPadding(12,8,12,8);
                tv.setTextSize(15);
                if (header) { tv.setTypeface(null, android.graphics.Typeface.BOLD);
                    tv.setBackgroundColor(0xFF1565C0); tv.setTextColor(0xFFFFFFFF); }
                else { tv.setBackgroundColor(0xFFE3F2FD); tv.setTextColor(0xFF212121); }
                tr.addView(tv);
            }
            tl.addView(tr);
            header = false;
        }
    }
}

