package com.example.bulbtoggle;
import android.os.Bundle;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
public class MainActivity extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);
        ImageView ivBulb    = findViewById(R.id.ivBulb);
        TextView tvStatus   = findViewById(R.id.tvStatus);
        ToggleButton toggle = findViewById(R.id.toggleBulb);
        toggle.setOnCheckedChangeListener((btn, isChecked) -> {
            if (isChecked) {
                ivBulb.setImageResource(R.drawable.bulb_on);
                ivBulb.setBackgroundColor(0xFFFFD600);
                tvStatus.setText("Bulb is ON");
                tvStatus.setTextColor(0xFF2E7D32);
            } else {
                ivBulb.setImageResource(R.drawable.bulb_off);
                ivBulb.setBackgroundColor(0xFFBBBBBB);
                tvStatus.setText("Bulb is OFF");
                tvStatus.setTextColor(0xFFB71C1C);
            }
        });
    }
}

