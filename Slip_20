package com.example.poweraverage;
import android.os.Bundle;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;
public class MainActivity2 extends AppCompatActivity {
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main2);
        double base = Double.parseDouble(getIntent().getStringExtra("base"));
        double exp  = Double.parseDouble(getIntent().getStringExtra("exp"));
        double power   = Math.pow(base, exp);
        double average = (base + exp) / 2;
        ((TextView) findViewById(R.id.tvPower)).setText("Power   = " + power);
        ((TextView) findViewById(R.id.tvAverage)).setText("Average = " + average);
    }
}

